{
  "$schema": "https://opencode.ai/config.json",
  "model": "9router/Free",
  "small_model": "9router/Emergency",
  "default_agent": "build",
  "plugin": [".opencode/plugins/intent-router.js"],

  "provider": {
    "9router": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Local 9Router",
      "options": {
        "baseURL": "http://localhost:20128/v1",
        "apiKey": "{env:NINEROUTER_API_KEY}"
      },
      "models": ${COMBO_MODELS}
    }
  },

  "instructions": [
    "{project}/.opencode/llm-mode.json",
    "{project}/.opencode/work-mode.json",
    "{project}/.opencode/pipeline-result.json",
    "{project}/.opencode/context.md",
    "{project}/instructions/user-rules.md",
    "{project}/instructions/preprocess.md",
    "{project}/instructions/plan-mode-rules.md",
    "{project}/instructions/build-mode-rules.md",
    "{project}/instructions/rules/README.md",
    "{project}/instructions/rules/01-pipeline-flow.md",
    "{project}/instructions/rules/02-mode-enforcement.md",
    "{project}/instructions/rules/03-model-routing.md",
    "{project}/instructions/rules/04-execution-rules.md",
    "{project}/instructions/rules/05-logging.md",
    "{project}/data/context/{context_file}.md"
  ],

  "skills": {
    "paths": ["{project}/ecc/skills", "{project}/data/skills"]
  },

  "agent": {
    "build": {
      "description": "Primary coding agent",
      "mode": "primary",
      "model": "9router/Free",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true,
        "read": true,
        "changed-files": true
      }
    },
    "planner": {
      "description": "Planning specialist.",
      "mode": "subagent",
      "model": "9router/Emergency",
      "prompt": "{file:{project}/ecc/.opencode/prompts/agents/planner.txt}",
      "tools": { "read": true, "bash": true, "write": false, "edit": false }
    },
    "code-reviewer": {
      "description": "Code review specialist.",
      "mode": "subagent",
      "model": "9router/Emergency",
      "prompt": "{file:{project}/ecc/.opencode/prompts/agents/code-reviewer.txt}",
      "tools": { "read": true, "bash": true, "write": false, "edit": false }
    },
    "security-reviewer": {
      "description": "Security specialist.",
      "mode": "subagent",
      "model": "9router/Free",
      "prompt": "{file:{project}/ecc/.opencode/prompts/agents/security-reviewer.txt}",
      "tools": { "read": true, "write": true, "edit": true, "bash": true }
    },
    "tdd-guide": {
      "description": "TDD specialist.",
      "mode": "subagent",
      "model": "9router/Free",
      "prompt": "{file:{project}/ecc/.opencode/prompts/agents/tdd-guide.txt}",
      "tools": { "read": true, "write": true, "edit": true, "bash": true }
    },
    "build-error-resolver": {
      "description": "Build error specialist.",
      "mode": "subagent",
      "model": "9router/Emergency",
      "prompt": "{file:{project}/ecc/.opencode/prompts/agents/build-error-resolver.txt}",
      "tools": { "read": true, "write": true, "edit": true, "bash": true }
    },
    "doc-updater": {
      "description": "Documentation specialist.",
      "mode": "subagent",
      "model": "9router/Emergency",
      "prompt": "{file:{project}/ecc/.opencode/prompts/agents/doc-updater.txt}",
      "tools": { "read": true, "write": true, "edit": true, "bash": true }
    }
  },

  "command": {
    "workmode": {
      "description": "Switch work mode: plan / build / status",
      "template": "py -m farewell_assistant.cli workmode $ARGUMENTS"
    },
    "start": {
      "description": "★ Consolidated: git pull + bootstrap + update + health + config + autostart + launch",
      "template": "py -m farewell_assistant.cli start $ARGUMENTS"
    },
    "daily": {
      "description": "★ Daily session: full startup + session log",
      "template": "py -m farewell_assistant.cli daily $ARGUMENTS"
    },
    "setup-project": {
      "description": "Register existing project from local path with auto code",
      "template": "py -m farewell_assistant.cli setup-project $ARGUMENTS"
    },
    "start-project": {
      "description": "List projects and activate one by code",
      "template": "py -m farewell_assistant.cli start-project $ARGUMENTS"
    },
    "project": {
      "description": "Switch active project by code (or list)",
      "template": "py -m farewell_assistant.cli project $ARGUMENTS"
    },
    "setup": {
      "description": "Set LLM mode (eco/on/hot/balance/performance) — redirects to llm-setup",
      "template": "py -m farewell_assistant.cli llm $ARGUMENTS"
    },
    "autostart": {
      "description": "Manage 9Router autostart: enable / disable / status",
      "template": "py -m farewell_assistant.cli autostart $ARGUMENTS"
    },
    "enrich-check": {
      "description": "Verify enrichment pipeline (local LLM preprocessor)",
      "template": "py -m farewell_assistant.cli enrich-check $ARGUMENTS"
    },
    "detect": {
      "description": "Detect project type from directory markers (Flutter/Node/Go/Rust/PHP/Python/.NET/...)",
      "template": "py -m farewell_assistant.cli detect $ARGUMENTS"
    },
    "llm-setup": {
      "description": "LLM config: auto/list/pull/status/remove + eco/on/hot/balance/performance",
      "template": "py -m farewell_assistant.cli llm $ARGUMENTS"
    },
    "go": {
      "description": "Universal task - goal-based execution",
      "template": "{file:{project}/commands/go.md}\n\n$ARGUMENTS"
    },
    "plan": {
      "description": "Create implementation plan",
      "template": "{file:{project}/ecc/.opencode/commands/plan.md}\n\n$ARGUMENTS",
      "agent": "planner",
      "subtask": true
    },
    "tdd": {
      "description": "TDD workflow",
      "template": "{file:{project}/ecc/.opencode/commands/tdd.md}\n\n$ARGUMENTS",
      "agent": "tdd-guide",
      "subtask": true
    },
    "code-review": {
      "description": "Code review",
      "template": "{file:{project}/ecc/.opencode/commands/code-review.md}\n\n$ARGUMENTS",
      "agent": "code-reviewer",
      "subtask": true
    },
    "security-scan": {
      "description": "Security review (OWASP)",
      "template": "{file:{project}/ecc/.opencode/commands/security.md}\n\n$ARGUMENTS",
      "agent": "security-reviewer",
      "subtask": true
    },
    "build-fix": {
      "description": "Fix build errors",
      "template": "{file:{project}/ecc/.opencode/commands/build-fix.md}\n\n$ARGUMENTS",
      "agent": "build-error-resolver",
      "subtask": true
    },
    "verify": {
      "description": "Run verification loop",
      "template": "{file:{project}/ecc/.opencode/commands/verify.md}\n\n$ARGUMENTS"
    },
    "update-docs": {
      "description": "Update documentation",
      "template": "{file:{project}/ecc/.opencode/commands/update-docs.md}\n\n$ARGUMENTS",
      "agent": "doc-updater",
      "subtask": true
    }
  },

  "permission": {
    "mcp_*": "ask"
  }
}
