{
  "$schema": "https://opencode.ai/config.json",
  "model": "9router/Deepseek-GO-Flash",
  "small_model": "9router/Free",
  "default_agent": "build",

  "provider": {
    "9router": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Local 9Router",
      "env": ["NINEROUTER_API_KEY"],
      "options": {
        "baseURL": "http://localhost:20128/v1",
        "apiKey": "{env:NINEROUTER_API_KEY}"
      },
      "models": {
        "Free": { "name": "Free (5 model Round Robin)" },
        "Deepseek-API-Flash": { "name": "Deepseek-API-Flash" },
        "Deepseek-API-Pro": { "name": "Deepseek-API-Pro" },
        "Deepseek-GO-Flash": { "name": "Deepseek-GO-Flash (Instructor)" },
        "Deepseek-GO-Pro": { "name": "Deepseek-GO-Pro" }
      }
    }
  },

  "instructions": [
    ".opencode/work-mode.json",
    ".opencode/context.md",
    "instructions/rules.md",
    ".farewell/context/farewell-assistant.md"
  ],

  "skills": {
    "paths": ["ecc/skills", ".farewell/custom-skills"]
  },

  "agent": {
    "build": {
      "description": "Primary coding agent",
      "mode": "primary",
      "model": "9router/Deepseek-GO-Flash",
      "tools": { "write": true, "edit": true, "bash": true, "read": true, "changed-files": true }
    },
    "planner": {
      "description": "Planning specialist.",
      "mode": "subagent",
      "model": "9router/Deepseek-GO-Flash",
      "prompt": "{file:ecc/.opencode/prompts/agents/planner.txt}",
      "tools": { "read": true, "bash": true, "write": false, "edit": false }
    },
    "code-reviewer": {
      "description": "Code review specialist.",
      "mode": "subagent",
      "model": "9router/Deepseek-GO-Flash",
      "prompt": "{file:ecc/.opencode/prompts/agents/code-reviewer.txt}",
      "tools": { "read": true, "bash": true, "write": false, "edit": false }
    },
    "security-reviewer": {
      "description": "Security specialist.",
      "mode": "subagent",
      "model": "9router/Deepseek-GO-Flash",
      "prompt": "{file:ecc/.opencode/prompts/agents/security-reviewer.txt}",
      "tools": { "read": true, "write": true, "edit": true, "bash": true }
    },
    "tdd-guide": {
      "description": "TDD specialist.",
      "mode": "subagent",
      "model": "9router/Deepseek-GO-Flash",
      "prompt": "{file:ecc/.opencode/prompts/agents/tdd-guide.txt}",
      "tools": { "read": true, "write": true, "edit": true, "bash": true }
    },
    "build-error-resolver": {
      "description": "Build error specialist.",
      "mode": "subagent",
      "model": "9router/Deepseek-GO-Flash",
      "prompt": "{file:ecc/.opencode/prompts/agents/build-error-resolver.txt}",
      "tools": { "read": true, "write": true, "edit": true, "bash": true }
    },
    "doc-updater": {
      "description": "Documentation specialist.",
      "mode": "subagent",
      "model": "9router/Deepseek-GO-Flash",
      "prompt": "{file:ecc/.opencode/prompts/agents/doc-updater.txt}",
      "tools": { "read": true, "write": true, "edit": true, "bash": true }
    }
  },

  "command": {
    "workmode": {
      "description": "Switch work mode: plan / build / status",
      "template": "py -m farewell_assistant workmode $ARGUMENTS"
    },
    "daily": {
      "description": "Daily: 9Router health + system status",
      "template": "py -m farewell_assistant daily $ARGUMENTS"
    },
    "project": {
      "description": "List or switch active project",
      "template": "py -m farewell_assistant project $ARGUMENTS"
    },
    "self-heal": {
      "description": "Post-edit typecheck hook",
      "template": "py -m farewell_assistant self-heal --file $ARGUMENTS"
    },
    "self-improvement": {
      "description": "Git pull ECC + 9Router",
      "template": "py -m farewell_assistant self-improvement $ARGUMENTS"
    },
    "start": {
      "description": "Switch project + footer",
      "template": "py -m farewell_assistant start-project $ARGUMENTS"
    },
    "start-project": {
      "description": "Switch active project + footer",
      "template": "py -m farewell_assistant start-project $ARGUMENTS"
    },
    "setup-project": {
      "description": "Register project from path",
      "template": "py -m farewell_assistant setup-project $ARGUMENTS"
    },
    "plan": {
      "description": "Create implementation plan",
      "template": "{file:ecc/.opencode/commands/plan.md}\n\n$ARGUMENTS",
      "agent": "planner",
      "subtask": true
    },
    "tdd": {
      "description": "TDD workflow",
      "template": "{file:ecc/.opencode/commands/tdd.md}\n\n$ARGUMENTS",
      "agent": "tdd-guide",
      "subtask": true
    },
    "code-review": {
      "description": "Code review",
      "template": "{file:ecc/.opencode/commands/code-review.md}\n\n$ARGUMENTS",
      "agent": "code-reviewer",
      "subtask": true
    },
    "security-scan": {
      "description": "Security review",
      "template": "{file:ecc/.opencode/commands/security.md}\n\n$ARGUMENTS",
      "agent": "security-reviewer",
      "subtask": true
    },
    "build-fix": {
      "description": "Fix build errors",
      "template": "{file:ecc/.opencode/commands/build-fix.md}\n\n$ARGUMENTS",
      "agent": "build-error-resolver",
      "subtask": true
    },
    "verify": {
      "description": "Run verification loop",
      "template": "{file:ecc/.opencode/commands/verify.md}\n\n$ARGUMENTS"
    },
    "update-docs": {
      "description": "Update documentation",
      "template": "{file:ecc/.opencode/commands/update-docs.md}\n\n$ARGUMENTS",
      "agent": "doc-updater",
      "subtask": true
    }
  },

  "permission": {
    "mcp_*": "ask"
  }
}
