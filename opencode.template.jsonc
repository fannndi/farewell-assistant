{
  "$schema": "https://opencode.ai/config.json",
  "model": "9router/${LEADER}",
  "small_model": "9router/${LEADER}",
  "default_agent": "build",

  "provider": {
    "9router": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Local 9Router",
      "env": ["NINEROUTER_API_KEY"],
      "options": {
        "baseURL": "http://localhost:20128/v1",
        "apiKey": "{env:NINEROUTER_API_KEY}"
      },
      "models": ${MODELS_JSON}
    }
  },

  "instructions": [
    ".opencode/work-mode.json",
    ".opencode/context.md",
    "instructions/rules.md",
    ".farewell/context/farewell-assistant.md",
    "ecc/AGENTS.md"
  ],

  "skills": {
    "paths": ${SKILL_PATHS}
  },

  "agent": {
    "build": {
      "description": "Primary coding agent",
      "mode": "primary",
      "model": "9router/${LEADER}",
      "tools": { "write": true, "edit": true, "bash": true, "read": true, "changed-files": true }
    },
    "team": {
      "description": "Team orchestrator — delegate to sub-agents",
      "mode": "primary",
      "model": "9router/${LEADER}",
      "tools": { "write": true, "edit": true, "bash": true, "read": true, "changed-files": true }
    },
    "planner": {
      "description": "Planning specialist.",
      "mode": "subagent",
      "model": "9router/${SPECIAL}",
      "prompt": "{file:ecc/.opencode/prompts/agents/planner.txt}",
      "tools": { "read": true, "bash": true, "write": false, "edit": false }
    },
    "architect": {
      "description": "Architecture and system design specialist.",
      "mode": "subagent",
      "model": "9router/${SPECIAL}",
      "prompt": "{file:ecc/.opencode/prompts/agents/architect.txt}",
      "tools": { "read": true, "bash": true, "write": false, "edit": false }
    },
    "code-reviewer": {
      "description": "Code review specialist.",
      "mode": "subagent",
      "model": "9router/${WORKER}",
      "prompt": "{file:ecc/.opencode/prompts/agents/code-reviewer.txt}",
      "tools": { "read": true, "bash": true, "write": false, "edit": false }
    },
    "security-reviewer": {
      "description": "Security specialist.",
      "mode": "subagent",
      "model": "9router/${WORKER}",
      "prompt": "{file:ecc/.opencode/prompts/agents/security-reviewer.txt}",
      "tools": { "read": true, "write": true, "edit": true, "bash": true }
    },
    "tdd-guide": {
      "description": "TDD specialist.",
      "mode": "subagent",
      "model": "9router/${WORKER}",
      "prompt": "{file:ecc/.opencode/prompts/agents/tdd-guide.txt}",
      "tools": { "read": true, "write": true, "edit": true, "bash": true }
    },
    "build-error-resolver": {
      "description": "Build error specialist.",
      "mode": "subagent",
      "model": "9router/${WORKER}",
      "prompt": "{file:ecc/.opencode/prompts/agents/build-error-resolver.txt}",
      "tools": { "read": true, "write": true, "edit": true, "bash": true }
    },
    "doc-updater": {
      "description": "Documentation specialist.",
      "mode": "subagent",
      "model": "9router/${WORKER}",
      "prompt": "{file:ecc/.opencode/prompts/agents/doc-updater.txt}",
      "tools": { "read": true, "write": true, "edit": true, "bash": true }
    },
    "python-reviewer": {
      "description": "Python code review specialist.",
      "mode": "subagent",
      "model": "9router/${WORKER}",
      "prompt": "{file:ecc/.opencode/prompts/agents/python-reviewer.txt}",
      "tools": { "read": true, "bash": true, "write": false, "edit": false }
    },
    "typescript-reviewer": {
      "description": "TypeScript/JavaScript code review specialist.",
      "mode": "subagent",
      "model": "9router/${WORKER}",
      "prompt": "{file:ecc/.opencode/prompts/agents/python-reviewer.txt}",
      "tools": { "read": true, "bash": true, "write": false, "edit": false }
    },
    "kotlin-reviewer": {
      "description": "Kotlin/Android code review specialist.",
      "mode": "subagent",
      "model": "9router/${WORKER}",
      "prompt": "{file:ecc/.opencode/prompts/agents/kotlin-reviewer.txt}",
      "tools": { "read": true, "bash": true, "write": false, "edit": false }
    },
    "database-reviewer": {
      "description": "SQL/schema query review specialist.",
      "mode": "subagent",
      "model": "9router/${WORKER}",
      "prompt": "{file:ecc/.opencode/prompts/agents/database-reviewer.txt}",
      "tools": { "read": true, "bash": true, "write": false, "edit": false }
    },
    "kotlin-build-resolver": {
      "description": "Kotlin/Gradle build error specialist.",
      "mode": "subagent",
      "model": "9router/${WORKER}",
      "prompt": "{file:ecc/.opencode/prompts/agents/kotlin-build-resolver.txt}",
      "tools": { "read": true, "write": true, "edit": true, "bash": true }
    },
    "java-reviewer": {
      "description": "Java/Spring Boot code review specialist.",
      "mode": "subagent",
      "model": "9router/${WORKER}",
      "prompt": "{file:ecc/.opencode/prompts/agents/java-reviewer.txt}",
      "tools": { "read": true, "bash": true, "write": false, "edit": false }
    },
    "docs-lookup": {
      "description": "Documentation lookup via Context7.",
      "mode": "subagent",
      "model": "9router/${HELPER}",
      "prompt": "{file:ecc/.opencode/prompts/agents/docs-lookup.txt}",
      "tools": { "read": true, "bash": true, "write": false, "edit": false }
    },
    "refactor-cleaner": {
      "description": "Dead code and refactoring specialist.",
      "mode": "subagent",
      "model": "9router/${HELPER}",
      "prompt": "{file:ecc/.opencode/prompts/agents/refactor-cleaner.txt}",
      "tools": { "read": true, "write": true, "edit": true, "bash": true }
    },
    "ketua-tim": {
      "description": "Ketua Tim — audit teknis, koordinasi, eksekusi langsung",
      "mode": "subagent",
      "model": "9router/${LEADER}",
      "prompt": "{file:ecc/.opencode/prompts/agents/planner.txt}",
      "tools": { "read": true, "write": true, "edit": true, "bash": true }
    },
    "backend-reviewer": {
      "description": "Backend audit — pegawai tetap, oc/mimo-v2.5-free",
      "mode": "subagent",
      "model": "9router/${WORKER}",
      "prompt": "{file:ecc/.opencode/prompts/agents/python-reviewer.txt}",
      "tools": { "read": true, "bash": true, "write": false, "edit": false }
    },
    "frontend-reviewer": {
      "description": "Frontend audit — pegawai tetap, oc/mimo-v2.5-free",
      "mode": "subagent",
      "model": "9router/${WORKER}",
      "prompt": "{file:ecc/.opencode/prompts/agents/typescript-reviewer.txt}",
      "tools": { "read": true, "bash": true, "write": false, "edit": false }
    },
    "worker-1": {
      "description": "Magang — dependensi, konfigurasi, tugas ringan",
      "mode": "subagent",
      "model": "9router/${HELPER}",
      "prompt": "{file:ecc/.opencode/prompts/agents/planner.txt}",
      "tools": { "read": true, "bash": true, "write": false, "edit": false }
    },
    "worker-2": {
      "description": "Magang — testing, lint, tugas ringan",
      "mode": "subagent",
      "model": "9router/${HELPER}",
      "prompt": "{file:ecc/.opencode/prompts/agents/planner.txt}",
      "tools": { "read": true, "bash": true, "write": false, "edit": false }
    },
    "worker-3": {
      "description": "Magang — dokumentasi, tugas ringan",
      "mode": "subagent",
      "model": "9router/${HELPER}",
      "prompt": "{file:ecc/.opencode/prompts/agents/planner.txt}",
      "tools": { "read": true, "bash": true, "write": false, "edit": false }
    }
  },

  "command": {
    "workmode": {
      "description": "Switch work mode: plan / build / status",
      "template": "py -m farewell_assistant workmode $ARGUMENTS"
    },
    "team": {
      "description": "Switch Divisi (on) / Tim (off) / status",
      "template": "py -m farewell_assistant team $ARGUMENTS"
    },
    "status": {
      "description": "Show current state",
      "template": "py -m farewell_assistant status $ARGUMENTS"
    },
    "daily": {
      "description": "All-in-one: start 9Router + upstream + sync + readiness check",
      "template": "py -m farewell_assistant daily $ARGUMENTS"
    },
    "project": {
      "description": "List or switch active project",
      "template": "py -m farewell_assistant project $ARGUMENTS"
    },
    "cool": {
      "description": "awesome-opencode: list/search/info/recommend/stats",
      "template": "py -m farewell_assistant cool $ARGUMENTS"
    },
    "org": {
      "description": "Organization hierarchy: chart / roles / workflow / priority",
      "template": "py -m farewell_assistant org $ARGUMENTS"
    }
  },

  "permission": {
    "mcp_*": "ask"
  }
}
